# Copy to `.env`. Only EXPO_PUBLIC_* is bundled into the app.

# Hosted API (production + photo-AI fallback when local api-server has no OPENAI_API_KEY).
EXPO_PUBLIC_API_URL=https://samewave.onrender.com
EXPO_PUBLIC_HOSTED_API_URL=https://samewave.onrender.com

# Physical device on same Wi‑Fi → your PC (use `ipconfig`, not 127.0.0.1).
EXPO_PUBLIC_DEV_API_URL=http://192.168.1.143:8787

# Clerk Dashboard → API Keys → Publishable key (pk_test_… or pk_live_…).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_a25vd2luZy1qYXdmaXNoLTQ1LmNsZXJrLmFjY291bnRzLmRldiQ

# Native/production builds only (dev usually leaves this unset):
# EXPO_PUBLIC_CLERK_PROXY_URL=https://samewave.onrender.com/api/__clerk
# EXPO_PUBLIC_DOMAIN=samewave.onrender.com
# EXPO_PUBLIC_APP_ORIGIN=https://yourdomain.com

# RevenueCat Dashboard → Project → API keys (optional until testing IAP).
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
