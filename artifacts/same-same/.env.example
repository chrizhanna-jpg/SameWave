# Copy to `.env`. Only EXPO_PUBLIC_* is bundled into the app.

# Hosted API (production + photo-AI fallback when local api-server has no OPENAI_API_KEY).
EXPO_PUBLIC_API_URL=https://samewave.onrender.com
EXPO_PUBLIC_HOSTED_API_URL=https://samewave.onrender.com

# Physical device on same Wi‑Fi → your PC (use `ipconfig`, not 127.0.0.1).
EXPO_PUBLIC_DEV_API_URL=http://192.168.1.143:8787

# Clerk Dashboard → API Keys → Publishable key (pk_test_… or pk_live_…).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_a25vd2luZy1qYXdmaXNoLTQ1LmNsZXJrLmFjY291bnRzLmRldiQ

# Optional: force SSO redirect (must match Clerk allowlist exactly). Native builds normally use package id:
# EXPO_PUBLIC_CLERK_SSO_REDIRECT=echo.samewaveripple.app://callback
# Legacy marketing scheme (only if still allowlisted in Clerk):
# EXPO_PUBLIC_CLERK_SSO_REDIRECT=same-same://callback

# Clerk Frontend API proxy — only for pk_live_* after you configure the proxy
# domain in Clerk Dashboard. Do NOT set for pk_test_* (breaks sign-in bootstrap).
# EXPO_PUBLIC_CLERK_PROXY_URL=https://samewave.onrender.com/api/__clerk
# EXPO_PUBLIC_DOMAIN=samewave.onrender.com
# EXPO_PUBLIC_APP_ORIGIN=https://yourdomain.com

# In-app purchases (RevenueCat). Leave unset or "false" for a free Play launch
# (Pro features unlocked, no paywalls, RevenueCat not initialized).
# Set to "true" when you are ready to sell Pro after launch.
# EXPO_PUBLIC_MONETIZATION_ENABLED=false

# Atlas Ripplefire / Wavefire: how many days of arcs can form a cluster (default 30).
# EXPO_PUBLIC_ATLAS_FIRE_WINDOW_DAYS=30

# Optional: force update modal/banner while testing in Expo Go (`pnpm dev:preview-update`).
# EXPO_PUBLIC_PREVIEW_UPDATE_UI=1

# RevenueCat Dashboard → Project → API keys (only needed when monetization is on).
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
