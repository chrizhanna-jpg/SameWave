# Copy to `.env` / `.env.local`. Only EXPO_PUBLIC_* is bundled into the app.

# Backend the app calls (pick one style):
# • Full origin (LAN phone → dev machine):
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:8787
# • Or public hostname only (HTTPS):
#   EXPO_PUBLIC_DOMAIN=api.yourdomain.com

# Production / staging backend (bundled releases). During `pnpm dev`,
# **`EXPO_PUBLIC_DEV_API_URL` and inferred LAN trump this** — so you can
# keep both lines without Atlas hitting Render by mistake on a LAN phone.
# Photo AI (`/api/analyze-photo`): if your LAN api-server has no OPENAI_API_KEY,
# the app retries this hosted URL automatically in Expo Go.
EXPO_PUBLIC_API_URL=https://samewave.onrender.com
# Local api-server on a physical phone (same Wi‑Fi as dev machine). Use your PC IPv4, not 127.0.0.1:
# EXPO_PUBLIC_DEV_API_URL=http://192.168.1.10:8787
# If EXPO_PUBLIC_API_URL must stay LAN-only, set hosted analyze fallback explicitly:
# EXPO_PUBLIC_HOSTED_API_URL=https://samewave.onrender.com
# Optional; duplicate debug NDJSON to this origin:7459 when Cursor ingest must receive device hits from LAN:
# EXPO_PUBLIC_DEBUG_INGEST_ORIGIN=http://192.168.1.10:7459
# Android USB only: adb reverse tcp:8787 tcp:8787 then http://127.0.0.1:8787 works on-device.

# Deep link / expo-router origin (optional override)
# EXPO_PUBLIC_APP_ORIGIN=https://yourdomain.com

# Clerk Dashboard → API Keys → Publishable key (pk_test_… or pk_live_…). Do not commit real values to git.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Production/native: same host as API, path /api/__clerk
# EXPO_PUBLIC_CLERK_PROXY_URL=https://samewave.onrender.com/api/__clerk
#
# Play Store / Google Sign-In (Clerk + Google Cloud):
# - Android package must match: app.json expo.android.package, Clerk Native Application ID,
#   and Google Cloud "Android" OAuth client package name (app.echo.samesame).
# - For AABs from Play: add SHA-1 and SHA-256 from Play Console → App integrity →
#   App signing key certificate (not debug keystore; upload key alone is insufficient for users).
# - Clerk → Native applications → Allowlist for mobile SSO redirect (add all):
#     same-same://callback
#     same-same://
#     app.echo.samesame://callback
#   (see utils/googleSsoRedirect.ts)

EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
