{
  "expo": {
    "name": "SameWave",
    "slug": "same-same",
    "version": "1.3.11",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": ["same-same", "echo.samewaveripple.app"],
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#166FFC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "echo.samewaveripple.app",
      "buildNumber": "11",
      "infoPlist": {
        "NSCameraUsageDescription": "SameWave uses your camera to take photos of your day so you can ripple with people sharing similar moments.",
        "NSPhotoLibraryUsageDescription": "SameWave lets you pick a photo from your library to share as today's moment.",
        "NSLocationWhenInUseUsageDescription": "SameWave uses your country (not precise location) to celebrate ripples with people nearby.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "echo.samewaveripple.app",
      "versionCode": 39,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#166FFC"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {}
      ],
      "@clerk/expo",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "SameWave needs access to your photo library so you can share a photo of today.",
          "cameraPermission": "SameWave needs your camera so you can take a photo of today."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SameWave needs your camera so you can take a photo of today."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SameWave uses your country (not precise location) to celebrate ripples with people nearby."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0A2552"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "pickFirst": [
                "META-INF/versions/9/OSGI-INF/MANIFEST.MF"
              ]
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "435d5953-8fbe-48a4-9b0c-85096db24c53"
      }
    },
    "owner": "chrizhanna",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/435d5953-8fbe-48a4-9b0c-85096db24c53",
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    }
  }
}
