NODE_ENV=development
LOG_LEVEL=info

PORT=8787
# Omit for LAN device testing from `http://YOUR_PC_IPV4:<PORT>` (defaults to `0.0.0.0`).
# LISTEN_HOST=127.0.0.1

# Neon: paste connection string from dashboard (?sslmode=require).
# Local Docker: `docker compose up -d` then use line below.
DATABASE_URL=postgresql://samesame:samesame_dev@127.0.0.1:5432/samesame

# Clerk Dashboard → API Keys (same app as same-same EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY).
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Photo insights (/api/analyze-photo) — required for theme/tags AI on the camera screen.
# Get from https://platform.openai.com/api-keys — paste into artifacts/api-server/.env only.
OPENAI_API_KEY=
# Leave empty for api.openai.com. Set only for Azure / OpenAI-compatible proxy.
OPENAI_BASE_URL=

# Legacy aliases (optional; OPENAI_* preferred):
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Optional admin endpoint guard
BACKFILL_ADMIN_TOKEN=

# Photo report alerts (2+ distinct reports on a photo → email moderation).
# https://resend.com/api-keys — verify your sending domain or use Resend onboarding address.
RESEND_API_KEY=
MODERATION_EMAIL_TO=samewaveripple@gmail.com
MODERATION_EMAIL_FROM=SameWave Moderation <onboarding@resend.dev>
