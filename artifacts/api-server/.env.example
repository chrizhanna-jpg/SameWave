NODE_ENV=development
LOG_LEVEL=info

# Required by src/index.ts
PORT=8787
# Omit for LAN device testing from `http://YOUR_PC_IPV4:<PORT>` (defaults to `0.0.0.0`).
# LISTEN_HOST=127.0.0.1

# Database — pick ONE:
# • Neon (no Docker): paste the "psql" / URI string from Neon (include ?sslmode=require if shown).
#   Example shape: postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# • Local Docker: `docker compose up -d` in this folder, then:
DATABASE_URL=postgresql://samesame:samesame_dev@127.0.0.1:5432/samesame

# Clerk
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=sk_test_mq5O7r9dqDmx1wFqKFCkQKURFwqeADaFC3PpexrNMo

# OpenAI (preferred names). Legacy aliases still work:
# AI_INTEGRATIONS_OPENAI_* 
OPENAI_API_KEY=
# Leave empty for api.openai.com. Only set if you use a proxy; must be a valid OpenAI-compatible base URL.
OPENAI_BASE_URL=

AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Optional admin endpoint guard
BACKFILL_ADMIN_TOKEN=
