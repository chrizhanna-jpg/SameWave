{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "seed:atlas-global": "node ./scripts/seed-atlas-global-demo.mjs",
    "extend:photo-retention": "node ./scripts/extend-photo-retention.mjs",
    "db:add-voter-photo-id": "node ./scripts/add-voter-photo-id-to-votes.mjs",
    "audit:photo-themes": "node ./scripts/audit-fix-photo-themes.mjs",
    "audit:photo-themes:apply": "node ./scripts/audit-fix-photo-themes.mjs --apply",
    "replace:viral-coffee": "node ./scripts/replace-viral-coffee-photo.mjs",
    "replace:viral-coffee:apply": "node ./scripts/replace-viral-coffee-photo.mjs --apply",
    "dev": "node ./scripts/dev.mjs",
    "sync:clerk-publishable": "node ./scripts/sync-clerk-publishable.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "@clerk/express": "^2.1.13",
    "@clerk/shared": "^4.10.0",
    "@google/genai": "^1.50.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "http-proxy-middleware": "^3.0.5",
    "openai": "^6.35.0",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "pg": "^8.20.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
