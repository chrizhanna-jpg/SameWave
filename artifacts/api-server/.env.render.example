# Copy these variable NAMES into Render → your api-server service → Environment.
# Values come from Clerk Dashboard, Neon, OpenAI, etc. Do not commit real secrets.

PORT=8787
DATABASE_URL=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
BACKFILL_ADMIN_TOKEN=
PHOTO_RETENTION_DAYS=90
# Closed-test / Play: bump when shipping a new AAB so the in-app banner appears.
ANDROID_LATEST_VERSION_CODE=42
ANDROID_LATEST_VERSION_NAME=1.3.14
ANDROID_UPDATE_MESSAGE=A new version of SameWave is ready with improved photo matching — update from the Play Store for the best experience.
