auto-install-peers=false
strict-peer-dependencies=false

# Local/registry metadata sometimes omits npm "time" fields; strict minimumReleaseAge then fails with
# ERR_PNPM_MISSING_TIME (semver, @types/node, etc.). Zero disables that gate for installs.
minimum-release-age=0

# Workaround when registry metadata is incomplete (pnpm suggests this for semver / @expo/cli).
resolution-mode=highest
